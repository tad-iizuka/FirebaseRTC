# LiveKit Cloud (または自前ホストLiveKitサーバー) のプロジェクト設定
# https://cloud.livekit.io/ の Project Settings > Keys から取得
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# LiveKitの管理API(RoomServiceClient/EgressClient)を叩くためのhttps URL。
# クライアント接続に使うwss://のURLとは別物なので注意
# (例: wss://xxxx.livekit.cloud に対して https://xxxx.livekit.cloud)。
# BANしたユーザーを即時キックする・録音(Egress)を開始する・送話ロック/録音状態を
# Room Metadataへ反映する、いずれにも使用する。
LIVEKIT_HOST=https://your-project.livekit.cloud

# ローカル起動時のポート (Cloud Runでは自動でPORTが注入されるため不要)
PORT=8080

# [フェーズ1: Firebase Auth]
# Firebase ConsoleのプロジェクトID (ID Tokenのaud検証に使用)
FIREBASE_PROJECT_ID=your-firebase-project-id

# ローカル開発時のみ必要。Firebase Console >
# プロジェクトの設定 > サービスアカウント > 新しい秘密鍵の生成 でダウンロードしたJSONのパス。
# Cloud Run本番環境では不要 (メタデータサーバー経由でADCが自動的に使われる)。
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Webクライアント(ptt-client)の実ドメインをカンマ区切りで指定。
# 例: https://ptt-client.example.com,https://ptt-client-dev.web.app
# 未設定の場合、ブラウザからのクロスオリジンfetchは全て拒否される(安全側のデフォルト)。
ALLOWED_ORIGINS=

# [フェーズ5: 録音機能(Egress)]
# Room Composite Egressの音声ファイル保存先はGCS(Google Cloud Storage)。
# 保存先バケット名。
RECORDING_GCS_BUCKET=your-recording-bucket

# GCSへの書き込み権限(Storage Object Admin等)を持つサービスアカウントの
# 認証情報。以下のいずれか一方を設定する:
#   - RECORDING_GCS_KEY_FILE: サービスアカウントJSONのファイルパス(ローカル開発用)
#   - RECORDING_GCS_CREDENTIALS_JSON: サービスアカウントJSONの中身をそのまま
#     文字列として設定(Cloud Run本番環境ではSecret Manager経由でこちらを使う)
#
# [注意] Firebase Admin SDKが使うGOOGLE_APPLICATION_CREDENTIALSとは別物として
# 扱う。GCPUploadのcredentialsはADC(Application Default Credentials)経由では
# なく、JSON文字列を直接要求するAPIのため、明示的にこちらを設定する必要がある。
# Cloud Run実行サービスアカウントと同じGCPプロジェクトのバケットであれば、
# 同じサービスアカウントキーを流用してもよい(ただしその場合はバケットに対する
# Storage Object Admin権限を別途付与すること)。
RECORDING_GCS_KEY_FILE=./recording-service-account.json
# RECORDING_GCS_CREDENTIALS_JSON=

# [フェーズ5: LiveKit Webhook]
# LiveKit Cloud (Settings > Webhooks) または自前ホストLiveKitの設定で、
# 以下のURLを登録しておく必要がある:
#   https://<このサーバーの公開URL>/webhooks/livekit
# 署名検証にはLIVEKIT_API_KEY/LIVEKIT_API_SECRETをそのまま流用するため、
# Webhook用の追加のシークレットは不要。
