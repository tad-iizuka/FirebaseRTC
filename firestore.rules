rules_version = '2';

// [設計方針]
// token-server/README.md に記載の設計をそのまま強制する:
//   - ルーム作成・参加(招待コード検証)・BAN・通報の書き込みは、すべて
//     token-server が Admin SDK 経由で行う(Admin SDKはこのルールをバイパスする)。
//   - クライアントからの直接書き込みは一切許可しない。
//   - 例外として、自分自身の members/{uid} ドキュメントの読み取りだけは許可する。
//     これはリアルタイムリスナーで「自分がBANされたこと」を即座にUIへ
//     反映するための補助であり、BAN自体の強制力はLiveKit側の即時キックが担う。
//   - [Phase5] チャットメッセージ(messages)は、ルームの「アクティブな」メンバーのみ
//     読み取り可能とする。BANされてstatusが'banned'に変わった瞬間、この条件を
//     満たさなくなり読み取り権限も自動的に失う(ボイスのBAN即時キックと同じ
//     二重の強制力を持たせる設計)。書き込みは引き続きAdmin SDK経由のみ。
//   - [Phase5] adminUsers(管理者権限の台帳)はクライアントに一切公開しない。
//     自分が管理者かどうかもクライアント側には開示せず、token-server側の
//     ミドルウェア(middleware/requireAdmin.js)だけが参照する。付与/剥奪は
//     dev-tools/grant-admin-permission.js でAdmin SDK経由・手動運用する。
//   - [Phase8] 監査ログ(auditLogs)・録音履歴(recordings)もクライアントへの
//     直接公開は行わない。閲覧はそれぞれ GET /admin/audit-logs
//     (audit:read権限)・GET /rooms/:roomId/recordings(メンバーのみ)経由に限定する。
service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomId} {
      // ルーム本体(inviteCode含む)はクライアントに一切公開しない。
      // 招待コードの検証は必ず token-server の POST /rooms/:roomId/join を通す。
      allow read, write: if false;

      match /members/{uid} {
        // 自分自身のメンバードキュメントのみ読み取り可(BAN即時反映のUI用)。
        allow read: if request.auth != null && request.auth.uid == uid;
        // role/status の変更(参加・BAN・BAN解除・moderator任命等)はすべて
        // サーバーAPI経由に限定。
        allow write: if false;
      }

      match /messages/{messageId} {
        // [Phase5: テキストチャット]
        // 自分がこのルームの「アクティブな」メンバーである場合のみ履歴を読める。
        // BANされてstatusが'banned'に変わった瞬間、この条件が false になり
        // 読み取り権限も自動的に失う(LiveKit即時キックと同様、二重の強制力を持たせる設計)。
        allow read: if request.auth != null &&
          exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid)).data.status == 'active';
        // 書き込みはtoken-server(Admin SDK経由)のみ。クライアントからの直接書き込みは禁止
        // (本文の長さチェック・レート制限をサーバー側で強制するため)。
        allow write: if false;
      }

      match /recordings/{recordingId} {
        // [Phase8] 録音履歴のメタデータ(ファイルパス等)。クライアントへの
        // 直接開示はせず、必ずtoken-server経由(GET /rooms/:roomId/recordings,
        // .../download-url)で取得させる(ダウンロードURL発行権限を
        // owner/moderatorに限定するため)。
        allow read, write: if false;
      }
    }

    match /reports/{reportId} {
      // 通報の受付・閲覧はサーバー(モデレーター運用)のみ。
      allow read, write: if false;
    }

    match /adminUsers/{uid} {
      // 管理者権限台帳。誰が管理者か、どの権限を持つかはクライアントに一切
      // 開示しない(自分自身のドキュメントであっても読み取り不可。
      // rooms/members とは異なり「即時UI反映」のニーズが無いための判断)。
      allow read, write: if false;
    }

    match /auditLogs/{logId} {
      // [Phase8] 監査ログ。GET /admin/audit-logs (audit:read権限) 経由でのみ
      // 閲覧可能。クライアントSDKからの直接読み書きは一切許可しない。
      allow read, write: if false;
    }

    // 上記以外のコレクション/ドキュメントへのアクセスはデフォルトで拒否。
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
